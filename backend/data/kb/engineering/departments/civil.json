  "vision": "To be the most sought after academic, research and practice based department of Civil Engineering that others would wish to emulate.",
  "mission": "Creating Exuberant Civil Engineering Professionals.",
  "labs": [
    {
      "name": "Fluid Mechanics Lab",
      "location": "Room B-102, Ground Floor",
      "description": "Equipped with hydraulic tilting flume, Pelton wheel and Francis turbine test rigs, wind tunnel, and momentum/viscosity apparatus."
    },
    {
      "name": "Engineering Geology Lab",
      "location": "Room A-202, Second Floor",
      "description": "Features a collection of approximately 550 mineral and rock samples, including metallic/non-metallic minerals and various rock types."
    },
    {
      "name": "Surveying Lab",
      "location": "Room B-105, Ground Floor",
      "description": "Equipped with modern surveying instruments including Total Stations, Theodolites, Auto/Tilting/Dumpy levels, GPS devices, and plane tables."
    },
    {
      "name": "Civil Engineering Project Lab",
      "location": "Room B-311, Third Floor",
      "description": "Equipped with specialized design and analysis software including AutoCAD, Revit, Tekla Structures, Primavera, and Gram++ GIS."
    },
    {
      "name": "Transportation Engineering Lab",
      "location": "Room B-106, Ground Floor",
      "description": "Equipped with ductility, impact, and abrasion testing machines, Marshall stability apparatus, and standard penetrometers."
    },
    {
      "name": "Geotechnical Engineering Lab",
      "location": "Room B-107, Ground Floor",
      "description": "Equipped for Tri-axial shear, direct shear, unconfined compression, vane shear, consolidation, CBR, and soil permeability testing."
    }
  ],
