  "labs": [
    {
      "name": "Design Studio",
      "location": "SOA Building",
      "description": "Spacious drafting rooms equipped with professional drawing boards, parallel rulers, and ergonomically designed seating."
    },
    {
      "name": "Building Construction Lab",
      "location": "SOA Building",
      "description": "Displays various construction details, materials assembly models, structural joints, and miniature scale structures."
    },
    {
      "name": "Climatology Lab",
      "location": "SOA Building",
      "description": "Equipped with solar scope, lux meters, wind anemometers, and thermometers for environmental and climate-responsive design analysis."
    },
    {
      "name": "Computer Aided Design (CAD) Lab",
      "location": "SOA Building",
      "description": "Workstations running CAD, Revit, SketchUp, Photoshop, and 3D modeling programs for digital representation."
    },
    {
      "name": "Model Making Workshop",
      "location": "SOA Building",
      "description": "Equipped with laser cutters, hot wire foam cutters, and wood/plastic working tools for 3D physical models creation."
    },
    {
      "name": "Material Museum",
      "location": "SOA Building",
      "description": "A comprehensive repository of construction materials, cladding specimens, paint finishes, hardware, and structural elements."
    }
  ],
